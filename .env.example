ARK_API_KEY=你的火山方舟API密钥
DEFAULT_MODEL_ID=doubao-seed-1-8-251228

# 可选模型列表（逗号分隔）
AVAILABLE_MODELS=doubao-seed-2-0-code-preview-260215,doubao-seed-1-8-251228,doubao-seed-2-0-lite-260215,doubao-seed-2-0-mini-260215,doubao-seed-2-0-pro-260215,deepseek-v3-2-251201,doubao-seed-code-preview-251028,doubao-seed-1-6-lite-251015,doubao-seed-translation-250915

# 排版审校 Vision 模型（多模态，能看图检查排版）
# 留空则跳过排版审校
# 支持多模态的模型：doubao-seed-1.8, doubao-seed-2.0-pro/lite/mini
VISION_MODEL_ID=doubao-seed-1-8-251228

# 支持多模态（图片输入）的模型列表，GUI 下拉框用
VISION_MODELS=doubao-seed-1-8-251228,doubao-seed-2-0-pro-260215,doubao-seed-2-0-lite-260215,doubao-seed-2-0-mini-260215

# 火山引擎视觉智能 OCR（扫描件 PDF 用）
# AK/SK 认证，和 Ark API Key 是两套体系
# 获取方式：火山引擎控制台 → 访问控制 → 访问密钥
VOLC_ACCESSKEY=你的AccessKeyID
VOLC_SECRETKEY=你的SecretAccessKey

# 日志级别: TRACE(完整LLM对话) / DEBUG(摘要) / INFO(默认) / WARNING
LOG_LEVEL=INFO
